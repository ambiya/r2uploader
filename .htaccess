<IfModule mod_rewrite.c>
    RewriteEngine On

    # If the request is for a real file or directory in public/, serve it
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Block access to sensitive files
<FilesMatch "\.(env|git|json|lock|md|ini)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Block access to directories
<IfModule mod_authz_core.c>
    <DirectoryMatch "^(.*/)(src|templates|data|vendor)/">
        Require all denied
    </DirectoryMatch>
</IfModule>

# PHP settings (only for mod_php; ignored by PHP-FPM)
<IfModule mod_php.c>
    php_value upload_max_filesize 512M
    php_value post_max_size 512M
    php_value max_execution_time 300
    php_value memory_limit 512M
</IfModule>
