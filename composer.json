{
    "name": "ambiya/r2uploader",
    "description": "PHP Cloudflare R2 Uploader and Manager",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "aws/aws-sdk-php": "^3.388",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "R2Uploader\\": "src/"
        },
        "files": [
            "src/Helpers/TranslationHelper.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
